---
import Layout from "../layouts/Layout.astro";
import NavModern from "../components/NavModern.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import ScrollReveal from "../components/ScrollReveal";
import TiltCard from "../components/TiltCard";
import { Image } from "astro:assets";
import escuelapgiImage from "../assets/escuelapgi.webp";
---

<Layout
  title="Proyectos de Desarrollo Web | Portafolio de Peko's"
  description="Explora nuestros proyectos de desarrollo web, desde landing pages hasta plataformas escolares integrales. Soluciones digitales de alta calidad."
>
  <NavModern />

  <!-- Hero Section -->
  <section class="page-hero">
    <div class="hero-background"></div>
    <div class="hero-grid"></div>
    <div class="hero-content">
      <ScrollReveal client:load direction="down" duration={0.8}>
        <span class="section-badge">Portafolio</span>
        <h1 class="hero-title">
          Mis <span class="highlight">Proyectos</span>
        </h1>
        <p class="hero-subtitle">
          Soluciones web desarrolladas con tecnologías modernas y enfoque en
          resultados
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="portafolio" class="portfolio-section">
    <div class="portfolio-grid">
      <!-- Proyecto Escuela PGI -->
      <ScrollReveal client:load delay={0.1}>
        <TiltCard client:load className="portfolio-card">
          <div class="portfolio-image-wrapper">
            <Image
              src={escuelapgiImage}
              alt="Plataforma Escolar Integral"
              class="portfolio-image"
            />
          </div>
          <div class="portfolio-content">
            <div class="portfolio-tags">
              <span class="portfolio-tag">React</span>
              <span class="portfolio-tag">Node.js</span>
              <span class="portfolio-tag">PostgreSQL</span>
              <span class="portfolio-tag">VPS</span>
            </div>
            <h3 class="portfolio-title">Plataforma Escolar Integral</h3>
            <p class="portfolio-description">
              Sistema web completo para gestión y difusión de información
              escolar. Incluye autenticación robusta, procesamiento de imágenes
              y animaciones modernas.
            </p>
            <a
              href="https://escuelapgi.cl/"
              target="_blank"
              rel="noopener noreferrer"
              class="portfolio-link"
            >
              Visitar Sitio →
            </a>
          </div>
        </TiltCard>
      </ScrollReveal>

      <!-- Garage Online -->
      <ScrollReveal client:load delay={0.2}>
        <TiltCard client:load className="portfolio-card">
          <div class="portfolio-image-wrapper">
            <img
              src="/garageonline.webp"
              alt="Garage Online"
              class="portfolio-image"
              loading="lazy"
            />
          </div>
          <div class="portfolio-content">
            <div class="portfolio-tags">
              <span class="portfolio-tag">Next.js</span>
              <span class="portfolio-tag">Node.js</span>
            </div>
            <h3 class="portfolio-title">Garage Online</h3>
            <p class="portfolio-description">
              Modernización completa del sitio web con Next.js y Node.js,
              enfocada en optimizar rendimiento y experiencia de usuario en la
              venta de repuestos y accesorios para motos.
            </p>
            <a
              href="https://www.garageonline.cl/"
              target="_blank"
              rel="noopener noreferrer"
              class="portfolio-link"
            >
              Ir a la Página →
            </a>
          </div>
        </TiltCard>
      </ScrollReveal>

      <!-- Portafolio Personal -->
      <ScrollReveal client:load delay={0.3}>
        <TiltCard client:load className="portfolio-card">
          <div class="portfolio-image-wrapper">
            <img
              src="/pekos-home.webp"
              alt="Portafolio Personal"
              class="portfolio-image"
              loading="lazy"
            />
          </div>
          <div class="portfolio-content">
            <div class="portfolio-tags">
              <span class="portfolio-tag">Astro</span>
              <span class="portfolio-tag">Tailwind</span>
              <span class="portfolio-tag">TypeScript</span>
            </div>
            <h3 class="portfolio-title">Portafolio Personal</h3>
            <p class="portfolio-description">
              Sitio web personal con diseño moderno, animaciones fluidas,
              efectos visuales y experiencia de usuario inmersiva.
            </p>
            <a
              href="https://github.com/keymers/portafolio.kevin"
              target="_blank"
              rel="noopener noreferrer"
              class="portfolio-link"
            >
              Ver Código →
            </a>
          </div>
        </TiltCard>
      </ScrollReveal>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  @import "../styles/redesign.css";

  .page-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 8rem 2rem 4rem;
    overflow: hidden;
  }

  .page-hero .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
  }

  html {
    scroll-behavior: smooth;
  }

  section {
    scroll-margin-top: 80px;
  }

  .portfolio-image-wrapper {
    overflow: hidden;
    border-radius: 20px 20px 0 0;
  }
</style>
