---
import Layout from "../layouts/Layout.astro";
import NavModern from "../components/NavModern.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import ScrollReveal from "../components/ScrollReveal";
---

<Layout
  title="Sobre Peko's | Expertos en Soluciones Informáticas"
  description="Conoce más sobre Kevin González y Peko's. Pasión por la tecnología y compromiso con la creación de soluciones informáticas innovadoras."
>
  <NavModern />

  <!-- Hero Section -->
  <section class="page-hero">
    <div class="hero-background"></div>
    <div class="hero-grid"></div>
    <div class="hero-content">
      <ScrollReveal client:load direction="down" duration={0.8}>
        <span class="section-badge">Sobre mí</span>
        <h1 class="hero-title">
          Kevin <span class="highlight">González Lister</span>
        </h1>
        <p class="hero-subtitle">
          Ingeniero Informático. Apasionado por la tecnología, la creatividad y
          el desarrollo de soluciones innovadoras.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- About Content Section -->
  <section class="about-section">
    <div class="about-container">
      <ScrollReveal client:load delay={0.1}>
        <div class="about-card">
          <div class="about-image-wrapper">
            <img
              src="/perfil.jpg"
              alt="Kevin González"
              class="about-image"
              loading="eager"
            />
          </div>
          <div class="about-content">
            <h2 class="about-title">Desarrollador y Solucionador de Problemas</h2>
            <p class="about-text">
              Siempre aprendiendo y buscando nuevos retos. Creo experiencias
              digitales que convierten visitantes en clientes, con diseño
              profesional, código limpio y resultados medibles.
            </p>
            <div class="about-links">
              <a
                href="https://www.linkedin.com/in/kevingonzalezlister/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  />
                </svg>
                LinkedIn
              </a>
              <a href="mailto:kevin.gonzalez@pekos.cl" class="btn-secondary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  />
                </svg>
                Email
              </a>
              <a
                href="/cv.pdf"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm4 18H6V4h7v5h5v11z"
                  />
                </svg>
                Descargar CV
              </a>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  @import "../styles/redesign.css";

  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 8rem 2rem 4rem;
    overflow: hidden;
  }

  .page-hero .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
  }

  .about-section {
    padding: 4rem 2rem 6rem;
  }

  .about-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .about-card {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: center;
    background: rgba(30, 41, 59, 0.5);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 24px;
    padding: 3rem;
  }

  .about-image-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid rgba(139, 92, 246, 0.3);
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.2);
  }

  .about-image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    object-position: top;
  }

  .about-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .about-text {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  html {
    scroll-behavior: smooth;
  }

  section {
    scroll-margin-top: 80px;
  }

  @media (max-width: 768px) {
    .about-card {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 2rem;
    }

    .about-image-wrapper {
      max-width: 200px;
      margin: 0 auto;
    }

    .about-links {
      justify-content: center;
    }
  }
</style>
